{
    "compilerOptions": {
        "allowJs": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "outDir": "./dist/",
        "paths": {
            "~/*": [
                "./src/*"
            ]
        },
        "rootDir": "./src/",
        "sourceMap": true,
        "strict": true,
        "target": "es6"
    },
    "include": [
        "./src/**/*",
        "declare.d.ts"
    ]
}